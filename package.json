{
  "name": "chip-8",
  "version": "1.0.0",
  "description": "A CHIP-8 Emulator written in Elm",
  "dependencies": {
    "elm-format": "=0.8.8",
    "elm-verify-examples": "=6.0.3",
    "uglify-js": "^3.19.3"
  },
  "scripts": {
    "build": "npm install && ./build.sh prod",
    "compile": "elm make --debug --output=docs/elm.min.js src/Main.elm",
    "doc-tests": "npx elm-verify-examples",
    "format": "npx elm-format --validate src",
    "lint": "npx elm-review",
    "serve": "cd docs && python3 -m http.server",
    "test": "npx elm-test tests"
  },
  "devDependencies": {
    "elm-review": "^2.7.6",
    "elm-test": "0.19.1-revision17"
  }
}
