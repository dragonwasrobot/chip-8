{
  "name": "chip-8",
  "version": "1.0.0",
  "description": "A CHIP-8 Emulator written in Elm",
  "dependencies": {
    "elm-format": "=0.8.8",
    "elm-test": "0.19.1-revision17",
    "elm-verify-examples": "=6.0.3",
    "uglify-js": "^3.19.3"
  },
  "scripts": {
    "build": "npm install && ./build.sh prod",
    "format": "./node_modules/.bin/elm-format --validate src",
    "review": "./node_modules/.bin/elm-review",
    "doc-tests": "./node_modules/.bin/elm-verify-examples",
    "test": "./node_modules/.bin/elm-test",
    "watch": "./node_modules/.bin/nodemon -e elm --watch src --exec '/bin/bash' ./build.sh"
  },
  "devDependencies": {
    "elm-review": "^2.7.6",
    "nodemon": "^2.0.20"
  }
}
