{
  "name": "chip-8",
  "version": "1.0.0",
  "description": "A CHIP-8 Emulator written in Elm",
  "dependencies": {
    "elm-format": "=0.8.8",
    "elm-verify-examples": "=6.0.3",
    "uglify-js": "^3.19.3"
  },
  "scripts": {
    "compile": "elm make --output=docs/elm.min.js src/Main.elm",
    "doc-tests": "elm-verify-examples",
    "format": "elm-format --validate src",
    "lint": "elm-review",
    "prepare": "husky",
    "serve": "cd docs && python3 -m http.server",
    "test": "elm-test tests"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.0.2",
    "elm-review": "^2.13.5",
    "elm-test": "0.19.1-revision17",
    "husky": "^9.1.7"
  },
  "packageManager": "pnpm@11.7.0"
}
